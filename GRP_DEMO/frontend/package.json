{
  "name": "ai-wardrobe-assistant",
  "version": "1.0.0",
  "description": "AI虚拟衣橱助手 - 基于 Vue3 + UniApp 的跨平台应用",
  "private": true,
  "scripts": {
    "dev:h5": "set UNI_INPUT_DIR=%cd%&& uni",
    "build:h5": "UNI_INPUT_DIR=$PWD uni build",
    "dev:mp-weixin": "UNI_INPUT_DIR=$PWD uni -p mp-weixin",
    "build:mp-weixin": "UNI_INPUT_DIR=$PWD uni build -p mp-weixin",
    "dev:mp-alipay": "UNI_INPUT_DIR=$PWD uni -p mp-alipay",
    "build:mp-alipay": "UNI_INPUT_DIR=$PWD uni build -p mp-alipay",
    "dev:mp-toutiao": "UNI_INPUT_DIR=$PWD uni -p mp-toutiao",
    "build:mp-toutiao": "UNI_INPUT_DIR=$PWD uni build -p mp-toutiao"
  },
  "dependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.0.0",
    "@dcloudio/uni-app": "3.0.0-4080720251210001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080720251210001",
    "@dcloudio/uni-h5": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-alipay": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4080720251210001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080720251210001",
    "sass": "^1.97.3",
    "vite": "5.2.8"
  },
  "engines": {
    "node": ">=18"
  }
}

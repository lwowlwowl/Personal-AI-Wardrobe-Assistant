% title page
\def\maketitle{
  \begin{titlepage}{
    \centering{
    \includegraphics[width=0.5\columnwidth]{images/nottingham-logo.png}} \par
    
    \vskip 1in \par 
    \LARGE {\bf \@title}
    
    \vskip 0.4in \par
    \large {\bf \@projectname}
  }
  
  \vskip 0.3in \par
  \large {\bf \@author} \par
  {\@studentid}
  
  \vskip 0.6in \par
  \large {\bf Supervised by \@supervisor}
  \vskip 0.2in \par
  \large {\bf Last Updated on \@submitdate}
  \vskip 0.3in \par
  \vspace*{\fill}
  \normalsize { School of Computer Science University of Nottingham Ningbo China}
  \end{titlepage}
}

\def\titlepage{
  \newpage
  \centering
  \linespread{1}
  \normalsize
  \vbox to \vsize\bgroup\vbox to 9in\bgroup
}
\def\endtitlepage{
  \par
  \kern 0pt
  \egroup
  \vss
  \egroup
  \clearpage
}


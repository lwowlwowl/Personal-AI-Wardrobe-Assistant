# 和风天气 API（用于 /api/weather/now 穿衣建议）
# 复制到 backend/.env 并填入真实值。改完务必重启后端。文档：https://dev.qweather.com/

# 使用控制台「API Host」专属域名，勿用 https://api.qweather.com
QWEATHER_API_HOST=https://你的专属API域名
QWEATHER_KID=你的密钥ID
QWEATHER_PROJECT_ID=你的项目ID
QWEATHER_PRIVATE_KEY_PATH=你的Ed25519私钥文件绝对路径

DASHSCOPE_API_KEY=你的dashscope的api
CLASSIFY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

DATABASE_URL=postgresql://{username}:{password}@localhost:5432/wardrobe_db 数据库url(去掉{}并填入你的信息)
SECRET_KEY=your-super-secret-key-change-this-in-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  (数据库的token过期时长)
